<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
</head>
<body>

    <h1><%= title %></h1>

    <ul>
        <% users.forEach(user => { %>

            <li>
                ID: <%= user.id %> <br>
                Nome: <%= user.name %> <br>
                Email: <%= user.email %>
            </li>

            <hr>

        <% }) %>
    </ul>

</body>
</html>